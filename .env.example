# Database (Supabase Postgres connection string — used by Drizzle + better-auth)
# Supabase Dashboard → Project Settings → Database → Connection string → "URI"
# Use the connection POOLER URI (port 6543) for serverless/Next.js.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase API (used by lib/supabase/client.ts)
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# Authentication
BETTER_AUTH_SECRET=your_secret_key_here

# OpenAI (for AI exam generation)
OPENAI_API_KEY=your_openai_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Gói đăng ký & thanh toán (VietQR chuyển khoản)
# ---------------------------------------------------------------------------
# Email được cấp quyền admin (xác nhận thanh toán, gia hạn). Phân tách bằng dấu phẩy.
ADMIN_EMAILS=hoivdpd10303@gmail.com

# Tài khoản ngân hàng nhận tiền — dùng để sinh mã QR VietQR (img.vietqr.io, không cần API key).
# PAYMENT_BANK_ID: mã ngân hàng theo VietQR — dùng mã BIN (vd 970436 = Vietcombank)
#   hoặc tên ngắn (vd VCB, TCB, MB, ACB, BIDV...). Tra cứu: https://api.vietqr.io/v2/banks
PAYMENT_BANK_ID=970436
PAYMENT_ACCOUNT_NO=0123456789
PAYMENT_ACCOUNT_NAME=NGUYEN VAN A
